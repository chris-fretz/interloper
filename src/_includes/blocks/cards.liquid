<section class="section cards">
    <div class="wrap">
        <div class="intro">
            {% if block.intro %}
                {{ block.intro | markdown }}
            {% endif %}
        </div>
        <div class="cards-wrap flex f-wrap f-center">
            {% for card in block.cards %}
            <article class="card rounded">
                <img src="{{ card.image }}" alt="{{ card.alt_text }}" width="420">
                <div class="wrap-content flex">
                    <h3>{{ card.heading }}</h3>
                    {{ card.content | markdown }}
                    <div class="flex f-center btn-wrap">
                        <a class="btn" href="{{ card.url }}" {% if card.new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ card.link_text }}</a>
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>